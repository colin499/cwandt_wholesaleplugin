# Shopify App credentials (from Partner Dashboard > Apps > your app)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Database
# Local dev: SQLite (no setup needed)
DATABASE_URL="file:./dev.db"
# Production (Postgres on Fly.io / Railway):
# DATABASE_URL="postgresql://user:password@host:5432/cwandt_wholesale?schema=public"

# App URL (set by Shopify CLI during dev; set explicitly in production)
# SHOPIFY_APP_URL=https://your-app.fly.dev

# CMS Integration (fill in once CMS API endpoint is ready)
# CMS_BASE_URL=https://cms.cwandt.com
# CMS_API_TOKEN=your_cms_bearer_token

# Shopify store (dev store for local testing)
# SHOPIFY_DEV_STORE=your-dev-store.myshopify.com
