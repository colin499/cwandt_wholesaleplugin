{% comment %}
  Block: Wholesale Line Sheet
  Add this block to any page section in the theme editor.

  Wholesale customers see a full product table with SKUs, retail prices,
  wholesale prices, MOQ, and stock availability — printable and PDF-exportable.
  Non-wholesale visitors see a login prompt.

  Requires wholesale-badge.liquid in the header (provides <meta name="wh-customer">
  which linesheet.js reads to confirm wholesale status without an async call).
{% endcomment %}

{% if customer and customer.tags contains 'wholesale' %}

  {{ 'linesheet.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'linesheet.js' | asset_url }}" defer></script>
  {% comment %} html2pdf.js loaded from CDN for PDF export {% endcomment %}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" defer></script>

  <div class="wh-linesheet">

    <div class="wh-ls-header wh-no-print">
      <div class="wh-ls-header-text">
        <h1 class="wh-ls-title">{{ block.settings.title | default: 'CW&T Wholesale Linesheet' }}</h1>
        <p class="wh-ls-subtitle">CONTACT : {{ block.settings.contact_email | default: 'hello@cwandt.com' }}</p>
        <div class="wh-ls-actions">
          <span id="wh-ls-save-state" class="wh-ls-save-state" aria-live="polite"></span>
          <button type="button" class="wh-ls-btn" id="wh-ls-print">Print</button>
          <div class="wh-ls-export-wrap">
            <button type="button" class="wh-ls-btn" id="wh-ls-export" aria-haspopup="true" aria-expanded="false">Export &#9662;</button>
            <div class="wh-ls-export-menu" id="wh-ls-export-menu" hidden>
              <button type="button" class="wh-ls-export-item" data-export="csv">Download CSV</button>
              <button type="button" class="wh-ls-export-item" data-export="pdf">Download PDF</button>
              <button type="button" class="wh-ls-export-item" data-export="gsheet">Open in Google Sheets</button>
            </div>
          </div>
        </div>
      </div>

      {% comment %}
        Customer panel — PO number, name, company, shipping address.
        Values filled by linesheet.js from /apps/wholesale/linesheet-draft.
      {% endcomment %}
      <div class="wh-ls-customer" id="wh-ls-customer">
        <p class="wh-ls-kv">
          <span class="wh-ls-key">PO #</span><span class="wh-ls-val"><input type="text" id="wh-ls-po" class="wh-ls-po-input" placeholder="optional" maxlength="120"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">NAME</span><span class="wh-ls-val" id="wh-ls-cust-name"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">COMPANY</span><span class="wh-ls-val" id="wh-ls-cust-company"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">EMAIL</span><span class="wh-ls-val" id="wh-ls-cust-email"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">SHIPPING</span><span class="wh-ls-val"><label class="wh-ls-own-label"><input type="checkbox" id="wh-ls-own-label"> I&rsquo;ll provide my own label</label></span>
        </p>
      </div>
    </div>

    {% comment %}
      Live totals bar — sticks below the site header while the sheet scrolls.
      Counts and subtotal update as quantities change; submit lives here.
    {% endcomment %}
    <div class="wh-ls-sticky wh-no-print">
      <span id="wh-ls-summary" class="wh-ls-summary"></span>
      <button type="button" class="wh-ls-btn wh-ls-btn--cart" id="wh-ls-submit-order">Submit Wholesale Order</button>
    </div>

    {% comment %} Print header — hidden on screen, visible when printing {% endcomment %}
    <div class="wh-ls-print-header wh-print-only">
      <p class="wh-ls-print-company">{{ block.settings.company_name | default: 'CW&T' }}</p>
      <p class="wh-ls-print-title">Wholesale Line Sheet</p>
    </div>

    <div id="wh-ls-order-result" class="wh-ls-order-result" role="status" aria-live="polite" hidden></div>

    <div id="wh-linesheet-loading" class="wh-ls-loading" aria-live="polite">
      Loading products&hellip;
    </div>

    <div id="wh-linesheet-content" hidden></div>

    {% comment %} Previous submitted order sheets — duplicate as a new draft {% endcomment %}
    <div id="wh-ls-history" class="wh-ls-history wh-no-print" hidden></div>

  </div>

{% else %}

  <div class="wh-ls-login-prompt">
    <p>
      Please <a href="/account/login">log in to your wholesale account</a> to access the line sheet.
    </p>
  </div>

{% endif %}

{% schema %}
{
  "name": "Wholesale Line Sheet",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "CW&T Wholesale Linesheet"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email (shown under the title)",
      "default": "hello@cwandt.com"
    },
    {
      "type": "text",
      "id": "company_name",
      "label": "Company Name (shown on PDF)",
      "default": "CW&T"
    }
  ]
}
{% endschema %}
