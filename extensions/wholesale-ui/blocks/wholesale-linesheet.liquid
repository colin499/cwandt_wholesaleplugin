{% comment %}
  Block: Wholesale Line Sheet
  Add this block to any page section in the theme editor.

  Wholesale customers see a full product table with SKUs, retail prices,
  wholesale prices, MOQ, and stock availability — printable and PDF-exportable.
  Non-wholesale visitors see a login prompt.

  Requires wholesale-badge.liquid in the header (provides <meta name="wh-customer">
  which linesheet.js reads to confirm wholesale status without an async call).
{% endcomment %}

{% liquid
  # Render for wholesale customers — and in the theme editor (design_mode),
  # where no customer is logged in, so the block stays visible and selectable.
  assign wh_show = false
  assign wh_tag_str = customer.tags | join: '|' | downcase | prepend: '|' | append: '|'
  if customer and wh_tag_str contains '|wholesale|'
    assign wh_show = true
  endif
  if request.design_mode
    assign wh_show = true
  endif
%}
{% if wh_show %}

  {{ 'linesheet.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'linesheet.js' | asset_url }}" defer></script>
  {% comment %} html2pdf.js loaded from CDN for PDF export {% endcomment %}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" defer></script>

  {% comment %}
    Live totals bar — sits OUTSIDE the padded .wh-linesheet shell so it can
    run flush under the site header, full-bleed. Sticks below the header
    while the sheet scrolls; counts and subtotal update as quantities
    change; submit lives here.
  {% endcomment %}
  <div class="wh-ls-sticky wh-no-print">
      <span id="wh-ls-save-state" class="wh-ls-save-state" aria-live="polite"></span>
      <span id="wh-ls-summary" class="wh-ls-summary"></span>
      <div class="wh-ls-sticky-actions">
        <button type="button" class="wh-ls-btn" id="wh-ls-clear" title="Set every quantity back to zero">Clear Sheet</button>
        <button type="button" class="wh-ls-btn" id="wh-ls-print">Print</button>
        <div class="wh-ls-export-wrap">
          <button type="button" class="wh-ls-btn" id="wh-ls-export" aria-haspopup="true" aria-expanded="false">Export &#9662;</button>
          <div class="wh-ls-export-menu" id="wh-ls-export-menu" hidden>
            <button type="button" class="wh-ls-export-item" data-export="csv">Download CSV</button>
            <button type="button" class="wh-ls-export-item" data-export="pdf">Download PDF</button>
            <button type="button" class="wh-ls-export-item" data-export="gsheet">Open in Google Sheets</button>
          </div>
        </div>
        <button type="button" class="wh-ls-btn wh-ls-btn--cart" id="wh-ls-submit-order" data-orders-url="{{ block.settings.orders_url | default: '/pages/orders' }}">Review Order &rarr;</button>
      </div>
  </div>

  <div class="wh-linesheet">

    {% comment %} Phones: wholesale is desktop-only — everything else in this
       block is hidden under 750px and this note shows instead. {% endcomment %}
    <p class="wh-mobile-note wh-no-print">
      Wholesale ordering is designed for a computer — please visit this page
      on a larger screen. On this device you&rsquo;re browsing the regular store.
    </p>

    <div class="wh-ls-header wh-no-print">
      {% comment %} No page heading — the topbar names the page (2026-07-19).
         The print/PDF header below keeps the full letterhead. {% endcomment %}
      {% comment %}
        Customer panel — PO number, name, company, shipping address.
        Values filled by linesheet.js from /apps/wholesale/linesheet-draft.
      {% endcomment %}
      <div class="wh-ls-customer" id="wh-ls-customer">
        <p class="wh-ls-kv">
          <span class="wh-ls-key">PO #</span><span class="wh-ls-val"><input type="text" id="wh-ls-po" class="wh-ls-po-input" placeholder="optional" maxlength="120"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">DATE</span><span class="wh-ls-val" id="wh-ls-date"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">NAME</span><span class="wh-ls-val" id="wh-ls-cust-name"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">COMPANY</span><span class="wh-ls-val" id="wh-ls-cust-company"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">EMAIL</span><span class="wh-ls-val" id="wh-ls-cust-email"></span>
        </p>
        <p class="wh-ls-kv">
          <span class="wh-ls-key">SHIPPING</span><span class="wh-ls-val"><label class="wh-ls-own-label"><input type="checkbox" id="wh-ls-own-label"> I&rsquo;ll provide my own label</label></span>
        </p>
      </div>

      {% comment %} Live filter — narrows the sheet as you type (display only;
         quantities, totals, and the saved draft are never affected). {% endcomment %}
      <div class="wh-ls-search">
        <span id="wh-ls-search-count" class="wh-ls-search-count" aria-live="polite"></span>
        <input type="search" id="wh-ls-search" class="wh-ls-search-input"
               placeholder="Search products" autocomplete="off" spellcheck="false"
               aria-label="Filter line sheet products">
      </div>
    </div>

    {% comment %}
      Print/PDF header — hidden on screen, shown when printing or exporting.
      Right-column values are mirrored from the live sheet by linesheet.js.
    {% endcomment %}
    <div class="wh-ls-print-header wh-print-only">
      <div class="wh-ls-print-left">
        <p class="wh-ls-print-company">CW&amp;T Wholesale Order Sheet</p>
        <p class="wh-ls-print-contact">CONTACT : {{ block.settings.contact_email | default: 'hello@cwandt.com' }}</p>
      </div>
      <div class="wh-ls-print-right">
        <p class="wh-ls-kv"><span class="wh-ls-key">PO #</span><span class="wh-ls-val" id="wh-ls-print-po"></span></p>
        <p class="wh-ls-kv"><span class="wh-ls-key">DATE</span><span class="wh-ls-val" id="wh-ls-print-date"></span></p>
        <p class="wh-ls-kv"><span class="wh-ls-key">NAME</span><span class="wh-ls-val" id="wh-ls-print-name"></span></p>
        <p class="wh-ls-kv"><span class="wh-ls-key">COMPANY</span><span class="wh-ls-val" id="wh-ls-print-company"></span></p>
        <p class="wh-ls-kv"><span class="wh-ls-key">EMAIL</span><span class="wh-ls-val" id="wh-ls-print-email"></span></p>
      </div>
    </div>
    <p class="wh-ls-print-summary wh-print-only" id="wh-ls-print-summary"></p>

    <div id="wh-ls-order-result" class="wh-ls-order-result" role="status" aria-live="polite" hidden></div>

    <div id="wh-linesheet-loading" class="wh-ls-loading" aria-live="polite">
      Loading products&hellip;
    </div>

    <div id="wh-linesheet-content" hidden></div>

  </div>

{% else %}

  <div class="wh-ls-login-prompt">
    <p>
      Please <a href="/account/login">log in to your wholesale account</a> to access the line sheet.
    </p>
  </div>

{% endif %}

{% schema %}
{
  "name": "Wholesale Line Sheet",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "orders_url",
      "label": "Orders page URL (Review Order hand-off)",
      "default": "/pages/orders"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email (shown under the title and on the PDF)",
      "default": "hello@cwandt.com"
    }
  ]
}
{% endschema %}
