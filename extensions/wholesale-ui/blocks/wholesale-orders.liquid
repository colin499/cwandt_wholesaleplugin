{% comment %}
  Block: Wholesale Orders
  Add this block to a page section (e.g. /pages/orders) in the theme editor.

  Wholesale customers see their submitted order sheets with live status
  (Submitted / Invoice sent / Preparing to ship / Shipped), expandable line
  detail, and a Reorder action that copies an order into a fresh draft on the
  order sheet page. Non-wholesale visitors see a login prompt.

  Data comes from /apps/wholesale/orders (App Proxy). Reorder posts to the
  existing /apps/wholesale/linesheet-duplicate endpoint, then redirects to the
  order sheet page, which prefills from the active draft on load.
{% endcomment %}

{% liquid
  # Render for wholesale customers — and in the theme editor (design_mode),
  # where no customer is logged in, so the block stays visible and selectable.
  assign wh_show = false
  if customer and customer.tags contains 'wholesale'
    assign wh_show = true
  endif
  if request.design_mode
    assign wh_show = true
  endif
%}
{% if wh_show %}

  {{ 'linesheet.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'orders.js' | asset_url }}" defer></script>

  <div
    class="wh-linesheet wh-orders"
    data-linesheet-url="{{ block.settings.linesheet_url | default: '/pages/linesheet' }}"
  >

    <div class="wh-ls-header">
      <div class="wh-ls-header-text">
        <h1 class="wh-ls-title">CW&amp;T Wholesale Order History</h1>
        <p class="wh-ls-subtitle">CONTACT : {{ block.settings.contact_email | default: 'hello@cwandt.com' }}</p>
      </div>
    </div>

    <div id="wh-orders-loading" class="wh-ls-loading" aria-live="polite">
      Loading orders&hellip;
    </div>

    <div id="wh-orders-content" hidden></div>

    <p class="wh-ls-orders-link">
      <a href="{{ block.settings.linesheet_url | default: '/pages/linesheet' }}">Start a new order &rarr;</a>
    </p>

  </div>

{% else %}

  <div class="wh-ls-login-prompt">
    <p>
      Please <a href="/account/login">log in to your wholesale account</a> to view your orders.
    </p>
  </div>

{% endif %}

{% schema %}
{
  "name": "Wholesale Orders",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email (shown under the title)",
      "default": "hello@cwandt.com"
    },
    {
      "type": "text",
      "id": "linesheet_url",
      "label": "Order sheet page URL (Reorder destination)",
      "default": "/pages/linesheet"
    }
  ]
}
{% endschema %}
