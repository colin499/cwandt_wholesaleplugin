{% comment %}
  Block: Wholesale Price Display
  Add this block to any product section in the theme editor.

  ── HOW THE LOGIN-DELAY BUG IS FIXED ────────────────────────────────────────
  The flash of retail price happened because the old approach used JavaScript
  to check customer status AFTER the page had already painted retail prices.

  This block fixes it with three server-side techniques:

  1. TAG CHECK IN LIQUID — `customer.tags contains 'wholesale'` is evaluated
     by Shopify's template engine on the server, before any HTML is sent to
     the browser. There is no async wait, no token timing issue.

  2. CSS VIA {% style %} — for wholesale customers, we inject CSS that hides
     the theme's retail price elements synchronously. The CSS is in <head>
     before the price element is even parsed. The retail price is never painted.

  3. META TAG — the wholesale-badge block emits <meta name="wh-customer"
     content="1"> which wholesale.js reads instantly (no fetch required).
     JavaScript only fetches actual price *numbers*, never customer *status*.
  ─────────────────────────────────────────────────────────────────────────────
{% endcomment %}

{% if customer and customer.tags contains 'wholesale' %}

  {% comment %}
    Suppress the theme's retail price elements so they are never painted.
    Using {% style %} injects this into <head> before the body renders.
    Selectors cover the most common Shopify theme conventions; adjust for
    your specific theme if needed (inspect the theme's price element classes).
  {% endcomment %}
  {% style %}
    product-price,
    .price,
    .price__regular,
    .price__sale,
    .price--main,
    .price-item--regular,
    .price-item--sale,
    [class*="product__price"],
    [class*="ProductPrice"] {
      display: none !important;
    }
    /* Wholesale PDP is informational — ordering happens on the line sheet.
       Hide the quantity selector and buy buttons (revealed again via
       html.wh-show-retail when the product is NOT in the program). */
    .product-form__quantity,
    .product-form__buttons,
    .product__inventory {
      display: none !important;
    }
    /* Reveal retail again when wholesale.js determines this product is NOT
       in the wholesale program (no CMS prices). Without this, a wholesale
       customer would see no price at all on retail-only products. */
    html.wh-show-retail product-price,
    html.wh-show-retail .price,
    html.wh-show-retail .price__regular,
    html.wh-show-retail .price__sale,
    html.wh-show-retail .price--main,
    html.wh-show-retail .price-item--regular,
    html.wh-show-retail .price-item--sale,
    html.wh-show-retail [class*="product__price"],
    html.wh-show-retail [class*="ProductPrice"],
    html.wh-show-retail .product-form__quantity,
    html.wh-show-retail .product-form__buttons,
    html.wh-show-retail .product__inventory {
      display: revert !important;
    }
  {% endstyle %}

  {% comment %} Load CSS and JS for the wholesale UI. {% endcomment %}
  {{ 'wholesale.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'wholesale.js' | asset_url }}" defer></script>

  {% comment %}
    The price block itself. `hidden` attribute means it starts invisible.
    wholesale.js removes `hidden` once prices are loaded.
    `data-wh-product-id` is how wholesale.js finds and activates this block.
  {% endcomment %}
  <div
    id="wh-price-block"
    class="wh-price-block"
    data-wh-product-id="{{ product.id }}"
    hidden
  >
    <p class="wh-price-row" id="wh-row-msrp" hidden>
      <span class="wh-price-key">MSRP</span><span class="wh-price-val" id="wh-price-msrp"></span>
    </p>
    <p class="wh-price-row">
      <span class="wh-price-key">WHOLESALE</span><span class="wh-price-val" id="wh-price-amount" aria-live="polite">—</span>
    </p>
    <p class="wh-price-row" id="wh-row-moq" hidden>
      <span class="wh-price-key">MOQ</span><span class="wh-price-val" id="wh-price-moq"></span>
    </p>
    <p class="wh-price-row" id="wh-row-case" hidden>
      <span class="wh-price-key">CASE SIZE</span><span class="wh-price-val" id="wh-price-case"></span>
    </p>
    <p class="wh-price-row" id="wh-row-stock" hidden>
      <span class="wh-price-key">STOCK</span><span class="wh-price-val" id="wh-price-stock"></span>
    </p>
    <p class="wh-price-discount-note" id="wh-discount-note"></p>
    <a
      class="wh-linesheet-link"
      href="{{ block.settings.linesheet_url | default: '/pages/linesheet' }}"
      target="_blank"
      rel="noopener"
    >Order on Linesheet &rarr;</a>
  </div>

{% else %}

  {% comment %}
    Retail visitor or logged-out: render nothing.
    Retail prices show normally (we do not inject any CSS here).
  {% endcomment %}

{% endif %}

{% schema %}
{
  "name": "Wholesale Price Display",
  "target": "section",
  "settings": [
    {
      "type": "url",
      "id": "linesheet_url",
      "label": "Linesheet page URL",
      "info": "Where 'Order on Linesheet' links to. Defaults to /pages/linesheet."
    }
  ],
  "templates": ["product", "page"]
}
{% endschema %}
